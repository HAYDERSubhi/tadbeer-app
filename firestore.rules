rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Personal user data ─────────────────────────────────────────────────
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Household / Family sharing ─────────────────────────────────────────
    match /households/{householdId} {

      // memberUids is a flat string[] — easy to check membership
      function isMember() {
        return request.auth != null
          && request.auth.uid in resource.data.memberUids;
      }

      function isOwner() {
        return request.auth != null
          && resource.data.ownerId == request.auth.uid;
      }

      // Any authenticated user can create a household
      allow create: if request.auth != null;

      // Only members can read / update; only owner can delete
      allow read:   if isMember();
      allow update: if isMember();
      allow delete: if isOwner();

      // Sub-collections (expenses, goals, settings): members only
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
      }

      match /{subcollection}/{docId}/{nested=**} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
      }
    }

    // ── Feedback (write-only for authenticated users) ──────────────────────
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
