
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Personal user data ─────────────────────────────────────────────────
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Household / Family sharing ─────────────────────────────────────────
    match /households/{householdId} {

      // Helper: is the requesting user a member of this household?
      function isMember() {
        return request.auth != null
          && exists(/databases/$(database)/documents/households/$(householdId))
          && request.auth.uid in resource.data.members.map(m, m.uid);
      }

      // Helper: is the requesting user the owner?
      function isOwner() {
        return request.auth != null
          && exists(/databases/$(database)/documents/households/$(householdId))
          && resource.data.ownerId == request.auth.uid;
      }

      // Household doc itself: members can read; owner can write; any auth user can create
      allow create: if request.auth != null;
      allow read:   if isMember();
      allow update: if isMember();   // members can update (e.g. join adds themselves via arrayUnion)
      allow delete: if isOwner();

      // Sub-collections (expenses, goals, settings): full access for members
      match /{subcollection}/{docId} {
        allow read, write: if isMember();
      }

      match /{subcollection}/{docId}/{nested=**} {
        allow read, write: if isMember();
      }
    }

    // ── Feedback (write-only for authenticated users) ──────────────────────
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
