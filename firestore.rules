rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Personal user data ─────────────────────────────────────────────────
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Household / Family sharing ─────────────────────────────────────────
    match /households/{householdId} {

      function isMember() {
        return request.auth != null
          && request.auth.uid in resource.data.memberUids;
      }

      function isOwner() {
        return request.auth != null
          && resource.data.ownerId == request.auth.uid;
      }

      allow create: if request.auth != null;
      allow read:   if isMember();
      allow update: if isMember();
      allow delete: if isOwner();

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
      }

      match /{subcollection}/{docId}/{nested=**} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
      }
    }

    // ── Referrals (any auth user can create; referrer can read their own) ──
    match /referrals/{referralId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null
        && resource.data.referrerUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Feedback (write-only for authenticated users) ──────────────────────
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
